---
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import PageMotion from '../components/motion/PageMotion';
import '../styles/global.css';

interface Props {
  title: string;
  showPageHeading?: boolean;
  mainClass?: string;
}

const { title, showPageHeading = true, mainClass = '' } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-background" aria-hidden="true">
      <span class="site-blob site-blob-left"></span>
      <span class="site-blob site-blob-right"></span>
      <span class="site-blob site-blob-center"></span>
    </div>
    <div class="site-shell" data-site-shell>
      <Header />
      <main class={`page-main ${mainClass}`.trim()}>
        {showPageHeading && (
          <section class="page-heading-wrap" data-reveal>
            <p class="page-kicker">Page Heading</p>
            <h1 class="page-title">{title}</h1>
          </section>
        )}
        <slot />
      </main>
      <Footer />
    </div>
    <PageMotion client:load />
  </body>
</html>
