---
import type { TypingMetric } from '../../lib/typing';

interface Props {
  metrics: TypingMetric[];
}

const { metrics } = Astro.props;
---

<section class="surface-card stack" data-reveal>
  <h2>推移チャート</h2>
  <div class="period-filter-wrap">
    <label for="period-filter">表示期間</label>
    <div class="period-filter-select">
      <select id="period-filter" aria-label="表示期間を選択">
        <option value="7">直近7日</option>
        <option value="30">直近30日</option>
        <option value="all" selected>全期間</option>
      </select>
    </div>
  </div>
  <div class="chart-wrapper">
    <canvas id="typing-chart" aria-label="タイピング推移" role="img"></canvas>
  </div>
</section>

<script type="module" define:vars={{ metrics }}>
  import {
    Chart,
    CategoryScale,
    Legend,
    LineController,
    LineElement,
    LinearScale,
    PointElement,
    Title,
    Tooltip,
  } from 'https://cdn.jsdelivr.net/npm/chart.js@4.4.2/+esm';

  Chart.register(
    CategoryScale,
    Legend,
    LineController,
    LineElement,
    LinearScale,
    PointElement,
    Title,
    Tooltip,
  );

  const sortedMetrics = [...metrics].sort(
    (a, b) => new Date(a.date).getTime() - new Date(b.date).getTime(),
  );

  const canvas = document.getElementById('typing-chart');
  const periodFilter = document.getElementById('period-filter');

  if (!(canvas instanceof HTMLCanvasElement) || !(periodFilter instanceof HTMLSelectElement)) {
    throw new Error('TypingChart initialization failed: required elements not found.');
  }

  const chart = new Chart(canvas, {
    type: 'line',
    data: {
      labels: sortedMetrics.map((item) => item.date),
      datasets: [
        {
          label: '総入力文字数',
          data: sortedMetrics.map((item) => item.totalChars),
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37, 99, 235, 0.2)',
          tension: 0.2,
          yAxisID: 'yChars',
        },
        {
          label: '正タイプ率 (%)',
          data: sortedMetrics.map((item) => (item.correctKeys / (item.correctKeys + item.errorKeys)) * 100),
          borderColor: '#16a34a',
          backgroundColor: 'rgba(22, 163, 74, 0.2)',
          tension: 0.2,
          yAxisID: 'yRate',
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      onClick: (_, elements) => {
        const [firstPoint] = elements;
        if (!firstPoint) {
          return;
        }

        const index = firstPoint.index;
        const targetDate = chart.data.labels?.[index];
        if (typeof targetDate === 'string') {
          window.location.href = `/typing/${encodeURIComponent(targetDate)}/`;
        }
      },
      plugins: {
        legend: {
          display: true,
        },
      },
      scales: {
        yChars: {
          type: 'linear',
          display: true,
          position: 'left',
          title: {
            display: true,
            text: '総入力文字数',
          },
        },
        yRate: {
          type: 'linear',
          display: true,
          position: 'right',
          min: 0,
          max: 100,
          grid: {
            drawOnChartArea: false,
          },
          title: {
            display: true,
            text: '正タイプ率 (%)',
          },
        },
      },
    },
  });

  function filterByDays(days) {
    if (days === 'all') {
      return sortedMetrics;
    }

    const dayCount = Number(days);
    if (!Number.isFinite(dayCount) || dayCount <= 0) {
      return sortedMetrics;
    }

    return sortedMetrics.slice(-dayCount);
  }

  function updateChart(days) {
    const filtered = filterByDays(days);
    const correctRates = filtered.map((item) => (item.correctKeys / (item.correctKeys + item.errorKeys)) * 100);
    const minRate = Math.min(...correctRates);
    const maxRate = Math.max(...correctRates);
    const range = maxRate - minRate;
    const padding = range === 0 ? 1 : Math.max(range * 0.1, 0.5);

    chart.data.labels = filtered.map((item) => item.date);
    chart.data.datasets[0].data = filtered.map((item) => item.totalChars);
    chart.data.datasets[1].data = correctRates;
    chart.options.scales.yRate.min = Math.max(0, minRate - padding);
    chart.options.scales.yRate.max = Math.min(100, maxRate + padding);
    chart.update();
  }

  periodFilter.addEventListener('change', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLSelectElement)) {
      return;
    }

    updateChart(target.value);
  });

  updateChart(periodFilter.value);
</script>

<style>
  #typing-chart {
    width: 100%;
    height: 100%;
    display: block;
  }

  .period-filter-wrap {
    display: grid;
    gap: 0.35rem;
    width: min(17rem, 100%);
  }

  .period-filter-wrap label {
    margin: 0;
    color: var(--subtext);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .period-filter-select {
    position: relative;
  }

  .period-filter-select::after {
    content: '▾';
    position: absolute;
    top: 50%;
    right: 0.9rem;
    transform: translateY(-50%);
    color: #1d4ed8;
    font-size: 0.9rem;
    pointer-events: none;
  }

  .period-filter-select select {
    width: 100%;
    border: 1px solid rgb(37 99 235 / 0.35);
    border-radius: 12px;
    padding: 0.62rem 2.2rem 0.62rem 0.85rem;
    background: linear-gradient(160deg, rgb(255 255 255 / 0.97), rgb(239 246 255 / 0.95));
    color: #0f172a;
    font-size: 0.95rem;
    font-weight: 600;
    box-shadow: 0 6px 14px rgb(15 23 42 / 0.09);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    appearance: none;
  }

  .period-filter-select select:hover {
    border-color: rgb(37 99 235 / 0.5);
  }

  .period-filter-select select:focus-visible {
    outline: none;
    border-color: rgb(37 99 235 / 0.85);
    box-shadow: 0 0 0 3px rgb(37 99 235 / 0.18), 0 8px 18px rgb(15 23 42 / 0.14);
    transform: translateY(-1px);
  }

  .chart-wrapper {
    height: clamp(320px, 45vh, 480px);
  }
</style>
