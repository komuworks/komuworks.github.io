---
import { toHome } from '../../lib/url';
import Nav from './Nav.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="site-header">
  <div class="header-inner">
    <p class="site-title">
      <a href={toHome()}>komuworks.github.io</a>
    </p>
    <h1 class="page-title">{title}</h1>
    <Nav />
  </div>
</header>
