---
import { formatDate } from '../../lib/format';
import { toBlogPost } from '../../lib/url';

interface Props {
  slug: string;
  title: string;
  summary: string;
  date: string;
  tags: string[];
}

const { slug, title, summary, date, tags } = Astro.props;
---

<article class="blog-card" data-reveal data-article-tags={JSON.stringify(tags)}>
  <p class="blog-meta">公開日: {formatDate(date)}</p>
  <h3 class="blog-title">
    <a href={toBlogPost(slug)}>{title}</a>
  </h3>
  <p>{summary}</p>
  <p class="blog-meta">{tags.map((tag) => `#${tag}`).join(' ')}</p>
</article>
