---
import { formatCount } from '../../lib/format';
import { toLearningDetail } from '../../lib/url';

interface Learning {
  slug: string;
  title: string;
  summary: string;
  period: string;
  detail: string[];
  goalSlugs: string[];
}

interface Props {
  learnings: Learning[];
}

const { learnings } = Astro.props;
---

<section class="surface-card stack" data-reveal>
  <p class="muted">学習テーマ: {formatCount(learnings.length)}</p>
  <ul class="profile-list">
    {learnings.map((learning) => (
      <li class="profile-card">
        <h3><a href={toLearningDetail(learning.slug)}>{learning.title}</a></h3>
        <p>{learning.summary}</p>
        <p class="blog-meta">期間: {learning.period}</p>
      </li>
    ))}
  </ul>
</section>
