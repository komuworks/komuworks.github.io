---
import { formatYearMonth } from '../../lib/format';

interface Certification {
  slug: string;
  organizer: string;
  name: string;
  result: string;
  acquiredDate: string;
  expiryDate: string | null;
}

interface Props {
  certifications: Certification[];
}

const { certifications } = Astro.props;
const currentYearMonth = new Date().toISOString().slice(0, 7);
const activeCertifications = certifications.filter(
  (certification) =>
    certification.expiryDate === null || certification.expiryDate >= currentYearMonth,
);
const defaultVisibleCount = 5;
const hiddenCertificationCount = Math.max(
  activeCertifications.length - defaultVisibleCount,
  0,
);
---

<section class="surface-card stack" data-reveal>
  <ul class="profile-list">
    {activeCertifications.map((certification, index) => (
      <li class="profile-card" data-hidden={index >= defaultVisibleCount ? 'true' : undefined}>
        <p class="blog-meta">{certification.organizer}</p>
        <strong>{certification.name}</strong>
        <p>{formatYearMonth(certification.acquiredDate)} {certification.result}</p>
      </li>
    ))}
  </ul>
  {hiddenCertificationCount > 0 && (
    <div class="show-more-wrap">
      <button
        type="button"
        class="show-more-button"
        data-expand-certifications
      >
        他{hiddenCertificationCount}件を表示する
      </button>
    </div>
  )}
</section>

<script is:inline>
  document.querySelectorAll('[data-expand-certifications]').forEach((button) => {
    button.addEventListener('click', () => {
      const section = button.closest('section');
      if (!section) return;
      section.querySelectorAll('[data-hidden="true"]').forEach((item) => {
        item.removeAttribute('data-hidden');
      });
      button.remove();
    });
  });
</script>

<style>
  [data-hidden='true'] {
    display: none;
  }

  .show-more-wrap {
    display: flex;
    justify-content: flex-end;
  }
</style>
