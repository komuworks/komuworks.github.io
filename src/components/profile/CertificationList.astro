---
import { formatYearMonth } from '../../lib/format';

interface Certification {
  slug: string;
  organizer: string;
  name: string;
  result: string;
  acquiredDate: string;
  expiryDate: string | null;
}

interface Props {
  certifications: Certification[];
}

const { certifications } = Astro.props;
---

<ul class="profile-list" data-reveal>
  {certifications.map((certification) => (
    <li class="profile-card">
      <strong>{certification.name}</strong>
      <p>{certification.organizer}</p>
      <p class="blog-meta">結果: {certification.result}</p>
      <p class="blog-meta">取得: {formatYearMonth(certification.acquiredDate)}</p>
      <p class="blog-meta">有効期限: {formatYearMonth(certification.expiryDate)}</p>
    </li>
  ))}
</ul>
