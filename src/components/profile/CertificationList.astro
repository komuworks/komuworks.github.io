---
import { formatCount, formatYearMonth } from '../../lib/format';

interface Certification {
  slug: string;
  organizer: string;
  name: string;
  result: string;
  acquiredDate: string;
  expiryDate: string | null;
}

interface Props {
  certifications: Certification[];
}

const { certifications } = Astro.props;
const currentYearMonth = new Date().toISOString().slice(0, 7);
const activeCertifications = certifications.filter(
  (certification) =>
    certification.expiryDate === null || certification.expiryDate >= currentYearMonth,
);
---

<section class="surface-card stack" data-reveal>
  <p class="muted">登録資格: {formatCount(activeCertifications.length)}</p>
  <ul class="profile-list">
    {activeCertifications.map((certification) => (
      <li class="profile-card">
        <p class="blog-meta">{certification.organizer}</p>
        <strong>{certification.name}</strong>
        <p>{formatYearMonth(certification.acquiredDate)} {certification.result}</p>
      </li>
    ))}
  </ul>
</section>
