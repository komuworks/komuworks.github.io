---
import { formatExperienceYears } from '../../lib/format';

interface SkillItem {
  name: string;
  years: number;
  level: number;
}

interface SkillCategory {
  category: string;
  items: SkillItem[];
}

interface Props {
  skills: SkillCategory[];
}

const { skills } = Astro.props;
const defaultVisibleCount = 5;

const getSegmentFillRate = (level: number, segmentIndex: number): number => {
  const normalizedLevel = Math.max(0, Math.min(level, 10));
  const totalSegments = 5;
  const filledSegments = (normalizedLevel / 10) * totalSegments;

  return Math.max(0, Math.min(filledSegments - segmentIndex, 1));
};
---

<section class="surface-card stack" data-reveal>
  {skills.map((skill, categoryIndex) => (
    <section class="stack">
      <h3>{skill.category}</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>スキル</th>
              <th class="col-years">経験年数</th>
              <th class="col-level">レベル</th>
            </tr>
          </thead>
          <tbody>
            {skill.items.map((item, itemIndex) => (
              <tr data-hidden={itemIndex >= defaultVisibleCount ? 'true' : undefined}>
                <td>{item.name}</td>
                <td class="col-years">{formatExperienceYears(item.years)}</td>
                <td class="col-level">
                  <div class="skill-level" aria-label={`レベル ${item.level} / 10`}>
                    <div class="skill-level__rating" aria-hidden="true">
                      {[...Array(5)].map((_, index) => (
                        <span class="skill-level__segment" style={`--fill-rate: ${getSegmentFillRate(item.level, index)};`} />
                      ))}
                    </div>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {skill.items.length > defaultVisibleCount && (
        <div class="show-more-wrap">
          <button
            type="button"
            class="show-more-button"
            data-expand-skill-category={categoryIndex}
          >
            他{skill.items.length - defaultVisibleCount}件を表示する
          </button>
        </div>
      )}
    </section>
  ))}
</section>

<script is:inline>
  document.querySelectorAll('[data-expand-skill-category]').forEach((button) => {
    button.addEventListener('click', () => {
      const section = button.closest('section');
      if (!section) return;
      section.querySelectorAll('tbody [data-hidden="true"]').forEach((row) => {
        row.removeAttribute('data-hidden');
      });
      button.remove();
    });
  });
</script>

<style>
  [data-hidden='true'] {
    display: none;
  }

  thead th {
    text-align: center;
  }

  td.col-years {
    width: 10ch;
    min-width: 10ch;
    max-width: 14ch;
    text-align: right;
    white-space: nowrap;
  }

  td.col-level {
    width: 9rem;
    min-width: 9rem;
    max-width: 12rem;
    text-align: center;
    white-space: nowrap;
  }

  .skill-level {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    width: 100%;
  }

  .skill-level__rating {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .skill-level__segment {
    --segment-bg: color-mix(in srgb, var(--text) 22%, transparent);
    --segment-fill: var(--accent);
    position: relative;
    width: 1rem;
    height: 0.6rem;
    border-radius: 0.15rem;
    transform: skewX(-24deg);
    overflow: hidden;
    background: var(--segment-bg);
  }

  .skill-level__segment::after {
    content: '';
    position: absolute;
    inset: 0;
    width: calc(var(--fill-rate) * 100%);
    background: var(--segment-fill);
  }

  .skill-level__text {
    white-space: nowrap;
  }

  .show-more-wrap {
    display: flex;
    justify-content: flex-end;
  }
</style>
