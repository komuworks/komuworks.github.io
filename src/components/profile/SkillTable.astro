---
import { formatExperienceYears, formatLevel } from '../../lib/format';
import { toSkillDetail } from '../../lib/url';

interface SkillItem {
  name: string;
  years: number;
  level: number;
}

interface SkillCategory {
  category: string;
  items: SkillItem[];
}

interface Props {
  skills: SkillCategory[];
}

const { skills } = Astro.props;
---

{skills.map((skill) => (
  <section class="surface-card stack" data-reveal>
    <h2>{skill.category}</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>スキル</th>
            <th>経験年数</th>
            <th>レベル</th>
          </tr>
        </thead>
        <tbody>
          {skill.items.map((item) => (
            <tr>
              <td>
                <a href={toSkillDetail(skill.category, item.name)}>{item.name}</a>
              </td>
              <td>{formatExperienceYears(item.years)}</td>
              <td>{formatLevel(item.level)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
))}
