---
import { formatCount } from '../../lib/format';
import { toGoalDetail } from '../../lib/url';

interface Goal {
  slug: string;
  title: string;
  summary: string;
  priority: string;
  targetPeriod: string;
  detail: string[];
}

interface Props {
  goals: Goal[];
}

const { goals } = Astro.props;
---

<section class="surface-card stack" data-reveal>
  <p class="muted">登録目標: {formatCount(goals.length)}</p>
  <ul class="profile-list">
    {goals.map((goal) => (
      <li class="profile-card">
        <h3><a href={toGoalDetail(goal.slug)}>{goal.title}</a></h3>
        <p>{goal.summary}</p>
        <p class="blog-meta">優先度: {goal.priority}</p>
      </li>
    ))}
  </ul>
</section>
