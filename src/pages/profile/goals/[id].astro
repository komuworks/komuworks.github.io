---
import { getEntry } from 'astro:content';
import GoalList from '../../../components/profile/GoalList.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const profileEntry = await getEntry('profile', 'index');
  const goals = profileEntry?.data.goals ?? [];

  return goals.map((goal) => ({
    params: { id: goal.slug },
    props: { goal, goals },
  }));
}

const { goal, goals } = Astro.props;
---

<BaseLayout title={goal.title}>
  <h2>{goal.title}</h2>
  <p>優先度: {goal.priority}</p>
  <p>期間: {goal.targetPeriod}</p>
  <ul>
    {goal.detail.map((item) => (
      <li>{item}</li>
    ))}
  </ul>

  <h2>目標一覧</h2>
  <GoalList goals={goals} />
</BaseLayout>
