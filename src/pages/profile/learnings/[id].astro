---
import { getEntry } from 'astro:content';
import LearningList from '../../../components/profile/LearningList.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const profileEntry = await getEntry('profile', 'index');
  const learnings = profileEntry?.data.learnings ?? [];

  return learnings.map((learning) => ({
    params: { id: learning.slug },
    props: { learning, learnings },
  }));
}

const { learning, learnings } = Astro.props;
---

<BaseLayout title={learning.title}>
  <section class="surface-card stack" data-reveal>
    <h2>{learning.title}</h2>
    <p>期間: {learning.period}</p>
    <p>{learning.summary}</p>
    <ul>
      {learning.detail.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <h2 data-reveal>学習一覧</h2>
  <LearningList learnings={learnings} />
</BaseLayout>
