---
import { getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { formatYearMonth } from '../../../lib/format';

export async function getStaticPaths() {
  const profileEntry = await getEntry('profile', 'index');
  const certifications = profileEntry?.data.certifications ?? [];

  return certifications.map((certification) => ({
    params: { id: certification.slug },
    props: { certification },
  }));
}

const { certification } = Astro.props;
---

<BaseLayout title={`資格の詳細`}>
  <section class="surface-card stack" data-reveal>
    <h2>{certification.name}</h2>
    <p>{formatYearMonth(certification.acquiredDate)} {certification.result}</p>
    <p>{certification.organizer}</p>
  </section>
</BaseLayout>
