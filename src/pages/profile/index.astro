---
import { getEntry } from 'astro:content';
import CertificationList from '../../components/profile/CertificationList.astro';
import GoalList from '../../components/profile/GoalList.astro';
import LearningList from '../../components/profile/LearningList.astro';
import SkillTable from '../../components/profile/SkillTable.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatCount } from '../../lib/format';

const profileEntry = await getEntry('profile', 'index');
const skills = profileEntry?.data.skills ?? [];
const certifications = profileEntry?.data.certifications ?? [];
const goals = profileEntry?.data.goals ?? [];
const learnings = profileEntry?.data.learnings ?? [];
---

<BaseLayout title="Profile">
  <section class="surface-card stack" data-reveal>
    <h2>自己紹介</h2>
    <p>名前: {profileEntry?.data.selfIntroduction.name}</p>
    <p>専門: {profileEntry?.data.selfIntroduction.specialty}</p>
    <p>志向: {profileEntry?.data.selfIntroduction.careerPreference}</p>
  </section>

  <section class="stack" data-reveal>
    <h2>資格</h2>
    <p class="blog-meta">登録数: {formatCount(certifications.length)}</p>
    <CertificationList certifications={certifications} />
  </section>

  <section class="stack" data-reveal>
    <h2>スキル</h2>
    <p class="blog-meta">カテゴリ数: {formatCount(skills.length)}</p>
    <SkillTable skills={skills} />
  </section>

  <h2 data-reveal>目標</h2>
  <GoalList goals={goals} />

  <h2 data-reveal>学習</h2>
  <LearningList learnings={learnings} />
</BaseLayout>
