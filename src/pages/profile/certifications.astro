---
import { getEntry } from 'astro:content';
import CertificationList from '../../components/profile/CertificationList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatCount } from '../../lib/format';

const profileEntry = await getEntry('profile', 'index');
const certifications = profileEntry?.data.certifications ?? [];
---

<BaseLayout title="Profile Certifications">
  <section class="surface-card stack" data-reveal>
    <p class="blog-meta">登録数: {formatCount(certifications.length)}</p>
  </section>
  <CertificationList certifications={certifications} />
</BaseLayout>
