---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  toBlogIndex,
  toGoalList,
  toHome,
  toLegacyHome,
  toProfileIndex,
  toTypingIndex,
} from '../lib/url';
import { getCollection } from 'astro:content';

const [blogEntries, typingEntries] = await Promise.all([
  getCollection('blog'),
  getCollection('typing'),
]);
---

<BaseLayout title="Home">
  <h1>トップページ</h1>
  <p>ブログ件数: {blogEntries.length}</p>
  <p>タイピング記録件数: {typingEntries.length}</p>

  <section aria-label="新サイト導線">
    <h2>新URL</h2>
    <ul>
      <li><a href={toHome()}>Home</a></li>
      <li><a href={toBlogIndex()}>Blog</a></li>
      <li><a href={toProfileIndex()}>Profile</a></li>
      <li><a href={toGoalList()}>Goals</a></li>
      <li><a href={toTypingIndex()}>Typing</a></li>
    </ul>
  </section>

  <section aria-label="旧サイト導線">
    <h2>旧サイト</h2>
    <p>
      旧版は引き続き参照できます: <a href={toLegacyHome()}>old/</a>
    </p>
  </section>
</BaseLayout>
