---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHeroMotion from '../components/motion/HomeHeroMotion';
import {
  toBlogIndex,
  toGoalList,
  toHome,
  toProfileIndex,
  toTypingIndex,
} from '../lib/url';
import { getCollection } from 'astro:content';

const [blogEntries, typingEntries] = await Promise.all([
  getCollection('blog'),
  getCollection('typing'),
]);
---

<BaseLayout title="Home">
  <HomeHeroMotion client:load>
    <span slot="blog-count">{blogEntries.length}</span>
    <span slot="typing-count">{typingEntries.length}</span>
  </HomeHeroMotion>

  <section aria-label="新サイト導線">
    <h2>新URL</h2>
    <ul>
      <li><a href={toHome()}>Home</a></li>
      <li><a href={toBlogIndex()}>Blog</a></li>
      <li><a href={toProfileIndex()}>Profile</a></li>
      <li><a href={toGoalList()}>Goals</a></li>
      <li><a href={toTypingIndex()}>Typing</a></li>
    </ul>
  </section>

</BaseLayout>
