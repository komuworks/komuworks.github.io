---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHeroMotion from '../components/motion/HomeHeroMotion';
import { toBlogIndex, toGoalList, toProfileIndex, toTypingIndex } from '../lib/url';
import { getCollection } from 'astro:content';

const [blogEntries, typingEntries] = await Promise.all([
  getCollection('blog'),
  getCollection('typing'),
]);
---

<BaseLayout title="Home" showPageHeading={false} mainClass="home-main">
  <section class="surface-card stack" data-reveal>
    <h2>Feature Photo</h2>
    <picture class="responsive-photo">
      <source
        type="image/webp"
        srcset="
          /images/hero-750.webp 750w,
          /images/hero-1280.webp 1280w,
          /images/hero-1920.webp 1920w,
          /images/hero-2560.webp 2560w,
          /images/hero-3840.webp 2840w,
          /images/hero-5120.webp 5120w
        "
        sizes="100vw"
      />
      <img
        src="/images/abarth-2560.jpg"
        srcset="
          /images/hero-750.jpg 750w,
          /images/hero-1280.jpg 1280w,
          /images/hero-1920.jpg 1920w,
          /images/hero-2560.jpg 2560w,
          /images/hero-3840.jpg 2840w,
          /images/hero-5120.jpg 5120w
        "
        sizes="100vw"
        alt="海沿いの防波堤に停車した車"
        loading="eager"
        decoding="async"
      />
    </picture>
  </section>

  <HomeHeroMotion
    blogHref={toBlogIndex()}
    profileHref={toProfileIndex()}
    goalsHref={toGoalList()}
    typingHref={toTypingIndex()}
    client:load
  >
    <span slot="blog-count">{blogEntries.length}</span>
    <span slot="typing-count">{typingEntries.length}</span>
  </HomeHeroMotion>

  <section class="surface-card stack" data-reveal>
    <h2>Welcome</h2>
    <p>
      すべてのページを通じて、Astroの構造とGSAPモーションで視認性と操作感を向上させました。ナビゲーションから各ページをぜひ確認してください。
    </p>
  </section>
</BaseLayout>
