---
import { readFile } from 'node:fs/promises';
import { resolve } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';

const mapDataDir = resolve(process.cwd(), 'public/geojson');
const dataFileNames = {
  admin0Topo: 'World Bank Official Boundaries - Admin 0.topo.json',
  admin1Topo: 'World Bank Official Boundaries - Admin 1.topo.json',
  admin1SimplifiedTopo: 'World Bank Official Boundaries - Admin 1.simplified.topo.json',
  // Legacy fallback (GeoJSON)
  admin0Geo: 'World Bank Official Boundaries - Admin 0.json',
  admin1Geo: 'World Bank Official Boundaries - Admin 1.json',
  admin1SimplifiedGeo: 'World Bank Official Boundaries - Admin 1.simplified.json',
  visitedStatus: 'visited-status-admin1.json'
};

let mapData:
  | {
      admin0Topology: unknown;
      admin1Topology: unknown;
      admin1SimplifiedTopology: unknown | null;
      visitedStatus: unknown;
    }
  | null = null;
let mapLoadError = false;

try {
  const visitedStatusRaw = await readFile(resolve(mapDataDir, dataFileNames.visitedStatus), 'utf-8');

  const readJsonWithFallback = async (primaryFileName: string, fallbackFileName: string) => {
    const primaryRaw = await readFile(resolve(mapDataDir, primaryFileName), 'utf-8').catch(() => null);
    if (primaryRaw) return JSON.parse(primaryRaw);

    const fallbackRaw = await readFile(resolve(mapDataDir, fallbackFileName), 'utf-8');
    return JSON.parse(fallbackRaw);
  };

  const [admin0Topology, admin1Topology] = await Promise.all([
    readJsonWithFallback(dataFileNames.admin0Topo, dataFileNames.admin0Geo),
    readJsonWithFallback(dataFileNames.admin1Topo, dataFileNames.admin1Geo)
  ]);
  const admin1SimplifiedTopology = await readJsonWithFallback(
    dataFileNames.admin1SimplifiedTopo,
    dataFileNames.admin1SimplifiedGeo
  ).catch(() => null);

  mapData = {
    admin0Topology,
    admin1Topology,
    admin1SimplifiedTopology,
    visitedStatus: JSON.parse(visitedStatusRaw)
  };
} catch (error) {
  console.error('Failed to load travel map topology data.', error);
  mapLoadError = true;
}
---

<BaseLayout title="Travel Map">
  <section class="surface-card stack travel-map-card" data-reveal>
    <h2>Travel Map</h2>

    {
      mapLoadError || !mapData ? (
        <p role="alert">地図データを読み込めませんでした</p>
      ) : (
        <>
          <p>マウスホイールで拡大縮小、ドラッグで地図を移動できます（しきい値: 2.5）。</p>
          <div id="travel-map-legend" class="travel-map-legend" aria-label="Map status legend"></div>
          <p id="travel-map-info" class="travel-map-info" aria-live="polite">地域にホバーすると詳細を表示します。</p>
          <div id="travel-map" class="travel-map" aria-label="Visited areas map"></div>
          <script id="travel-map-data" type="application/json" set:html={JSON.stringify(mapData)}></script>
        </>
      )
    }
  </section>
</BaseLayout>

<script>
  const ADMIN1_VISIBLE_ZOOM = 2.5;
  const MIN_SCALE = 1;
  const MAX_SCALE = 48;
  const ZOOM_SPEED = 0.0018;

  const dataElement = document.getElementById('travel-map-data');
  const mapRoot = document.getElementById('travel-map');
  const legendRoot = document.getElementById('travel-map-legend');
  const infoRoot = document.getElementById('travel-map-info');

  if (!dataElement || !mapRoot || !legendRoot || !infoRoot) {
    throw new Error('Travel map initialization failed.');
  }

  const mapData = JSON.parse(dataElement.textContent ?? '{}');
  const topologyToFeatureCollection = (topology) => {
    if (!topology || typeof topology !== 'object') return [];

    // Backward-compatibility: legacy GeoJSON payloads
    if ('features' in topology && Array.isArray(topology.features)) {
      return topology.features;
    }

    if (topology.type !== 'Topology' || !Array.isArray(topology.arcs) || !topology.objects || typeof topology.objects !== 'object') {
      return [];
    }

    const transform = topology.transform;
    const decodedArcs = topology.arcs.map((arc) => {
      if (!Array.isArray(arc)) return [];
      let x = 0;
      let y = 0;

      return arc.map((point) => {
        if (!Array.isArray(point) || point.length < 2) return [0, 0];
        x += point[0];
        y += point[1];

        if (transform?.scale && transform?.translate) {
          return [x * transform.scale[0] + transform.translate[0], y * transform.scale[1] + transform.translate[1]];
        }

        return [x, y];
      });
    });

    const getArcCoordinates = (arcIndex) => {
      if (typeof arcIndex !== 'number') return [];
      if (arcIndex >= 0) {
        return decodedArcs[arcIndex] ?? [];
      }

      const reversedArc = decodedArcs[~arcIndex] ?? [];
      return [...reversedArc].reverse();
    };

    const mergeArcs = (arcIndices) => {
      const coordinates = [];

      for (const [index, arcIndex] of arcIndices.entries()) {
        const arc = getArcCoordinates(arcIndex);
        if (arc.length === 0) continue;

        coordinates.push(...(index === 0 ? arc : arc.slice(1)));
      }

      return coordinates;
    };

    const topologyGeometryToGeoJson = (geometry) => {
      if (!geometry || typeof geometry !== 'object') return null;

      if (geometry.type === 'Polygon') {
        return {
          type: 'Polygon',
          coordinates: (geometry.arcs ?? []).map((ringArcIndices) => mergeArcs(ringArcIndices))
        };
      }

      if (geometry.type === 'MultiPolygon') {
        return {
          type: 'MultiPolygon',
          coordinates: (geometry.arcs ?? []).map((polygonArcIndices) =>
            polygonArcIndices.map((ringArcIndices) => mergeArcs(ringArcIndices))
          )
        };
      }

      if (geometry.type === 'Point') {
        const [x = 0, y = 0] = geometry.coordinates ?? [];
        if (transform?.scale && transform?.translate) {
          return {
            type: 'Point',
            coordinates: [x * transform.scale[0] + transform.translate[0], y * transform.scale[1] + transform.translate[1]]
          };
        }

        return { type: 'Point', coordinates: [x, y] };
      }

      if (geometry.type === 'MultiPoint') {
        const coordinates = (geometry.coordinates ?? []).map(([x = 0, y = 0]) => {
          if (transform?.scale && transform?.translate) {
            return [x * transform.scale[0] + transform.translate[0], y * transform.scale[1] + transform.translate[1]];
          }
          return [x, y];
        });

        return { type: 'MultiPoint', coordinates };
      }

      return null;
    };

    const objectKeys = Object.keys(topology.objects);
    if (objectKeys.length === 0) return [];

    const firstObject = topology.objects[objectKeys[0]];
    if (!firstObject || typeof firstObject !== 'object') return [];

    if (firstObject.type === 'GeometryCollection') {
      return (firstObject.geometries ?? [])
        .map((geometry) => {
          const geoJsonGeometry = topologyGeometryToGeoJson(geometry);
          if (!geoJsonGeometry) return null;

          return {
            type: 'Feature',
            id: geometry.id,
            properties: geometry.properties ?? {},
            geometry: geoJsonGeometry
          };
        })
        .filter(Boolean);
    }

    const geoJsonGeometry = topologyGeometryToGeoJson(firstObject);
    if (!geoJsonGeometry) return [];

    return [
      {
        type: 'Feature',
        id: firstObject.id,
        properties: firstObject.properties ?? {},
        geometry: geoJsonGeometry
      }
    ];
  };

  const admin0Features = topologyToFeatureCollection(mapData?.admin0Topology);
  const admin1RawFeatures = topologyToFeatureCollection(mapData?.admin1Topology);
  const admin1SimplifiedFeatures = topologyToFeatureCollection(mapData?.admin1SimplifiedTopology);
  const shouldPreferSimplifiedAdmin1 = window.matchMedia('(max-width: 768px)').matches;
  const admin1Features =
    shouldPreferSimplifiedAdmin1 && admin1SimplifiedFeatures.length > 0 ? admin1SimplifiedFeatures : admin1RawFeatures;
  const visitedStatusPayload = mapData?.visitedStatus ?? {};
  const statusMeta = visitedStatusPayload?.statusMeta ?? {};
  const statusDisplayName = {
    lived: '居住',
    stayed: '宿泊',
    visited: '訪問',
    passed: '通過',
    want_to_go: '行きたい',
    unknown: '未設定'
  };
  const idKey = typeof visitedStatusPayload?.idKey === 'string' ? visitedStatusPayload.idKey : 'ADM1CD_c';
  const statusPriority = ['lived', 'stayed', 'visited', 'passed', 'want_to_go', 'unknown'];
  const statusRank = new Map(statusPriority.map((status, index) => [status, index]));
  const normalizeStatus = (status) => {
    if (typeof status !== 'string') return 'unknown';
    const normalizedStatus = status.toLowerCase();
    return statusRank.has(normalizedStatus) ? normalizedStatus : 'unknown';
  };
  const rawAdmin1StatusById =
    visitedStatusPayload?.statuses && typeof visitedStatusPayload.statuses === 'object'
      ? visitedStatusPayload.statuses
      : {};
  const admin1StatusById = Object.fromEntries(
    Object.entries(rawAdmin1StatusById).map(([admin1Id, value]) => {
      const rawStatus =
        typeof value === 'string' ? value : value && typeof value === 'object' ? value.status : undefined;
      return [admin1Id, normalizeStatus(rawStatus)];
    })
  );

  const aggregateStatus = (statuses) => {
    let bestStatus = 'unknown';
    let bestRank = statusRank.get(bestStatus);

    for (const status of statuses) {
      const normalizedStatus = normalizeStatus(status);
      const rank = statusRank.get(normalizedStatus);
      if (rank === undefined) continue;
      if (bestRank === undefined || rank < bestRank) {
        bestStatus = normalizedStatus;
        bestRank = rank;
      }
    }

    return bestStatus;
  };

  for (const status of statusPriority) {
    const meta = statusMeta?.[status];
    if (!meta) continue;

    const item = document.createElement('div');
    item.className = 'travel-map-legend__item';
    const swatch = document.createElement('span');
    swatch.className = 'travel-map-legend__swatch';
    swatch.style.backgroundColor = meta.color;
    const label = document.createElement('span');
    label.textContent = statusDisplayName[status] ?? meta.label ?? statusDisplayName.unknown;
    item.append(swatch, label);
    legendRoot.append(item);
  }

  const mercatorY = (latDeg) => {
    const clampedLat = Math.max(-85, Math.min(85, latDeg));
    const rad = (clampedLat * Math.PI) / 180;
    return Math.log(Math.tan(Math.PI / 4 + rad / 2));
  };

  const mercatorX = (lonDeg) => (lonDeg * Math.PI) / 180;

  const bounds = { minX: Infinity, minY: Infinity, maxX: -Infinity, maxY: -Infinity };
  const walkCoordinates = (coordinates, cb) => {
    if (typeof coordinates[0] === 'number' && typeof coordinates[1] === 'number') {
      cb(coordinates[0], coordinates[1]);
      return;
    }

    for (const child of coordinates) {
      walkCoordinates(child, cb);
    }
  };

  for (const feature of [...admin0Features, ...admin1Features]) {
    walkCoordinates(feature.geometry.coordinates, (lon, lat) => {
      const mx = mercatorX(lon);
      const my = mercatorY(lat);
      bounds.minX = Math.min(bounds.minX, mx);
      bounds.maxX = Math.max(bounds.maxX, mx);
      bounds.minY = Math.min(bounds.minY, my);
      bounds.maxY = Math.max(bounds.maxY, my);
    });
  }

  // Keep the horizontal world extent fixed to [-180, 180] so repeated tiles
  // connect seamlessly at the antimeridian.
  bounds.minX = mercatorX(-180);
  bounds.maxX = mercatorX(180);

  const width = 1200;
  const height = 640;
  const padding = 20;
  const scaleX = (width - padding * 2) / (bounds.maxX - bounds.minX);
  const scaleY = (height - padding * 2) / (bounds.maxY - bounds.minY);
  const fitScale = Math.min(scaleX, scaleY);

  const project = (lon, lat) => {
    const xMerc = mercatorX(lon);
    const x = padding + (xMerc - bounds.minX) * fitScale;
    const yMerc = mercatorY(lat);
    const y = height - padding - (yMerc - bounds.minY) * fitScale;
    return [x, y];
  };

  const DATELINE_THRESHOLD = 180;
  const EPSILON = 1e-6;

  const pointsEqual = (a, b) => a?.[0] === b?.[0] && a?.[1] === b?.[1];

  const closeRing = (ring) => {
    if (ring.length === 0) return ring;
    return pointsEqual(ring[0], ring[ring.length - 1]) ? ring : [...ring, [...ring[0]]];
  };

  const splitRingOnDateline = (ring, threshold = DATELINE_THRESHOLD) => {
    if (!Array.isArray(ring) || ring.length < 2) return [ring];

    const workingRing = closeRing(ring);
    const splitRings = [];
    let currentRing = [[...workingRing[0]]];

    for (let index = 0; index < workingRing.length - 1; index += 1) {
      const [lon1, lat1] = workingRing[index];
      const [lon2, lat2] = workingRing[index + 1];
      const deltaLon = lon2 - lon1;

      if (Math.abs(deltaLon) > threshold) {
        const wrappedDeltaLon = deltaLon > 0 ? deltaLon - 360 : deltaLon + 360;
        const boundaryLon = deltaLon > 0 ? -180 : 180;
        const tRaw = wrappedDeltaLon === 0 ? 0 : (boundaryLon - lon1) / wrappedDeltaLon;
        const t = Math.min(1, Math.max(0, tRaw));
        const interpolatedLat = lat1 + (lat2 - lat1) * t;

        const snappedBoundaryLon = boundaryLon > 0 ? 180 : -180;
        const oppositeBoundaryLon = snappedBoundaryLon === 180 ? -180 : 180;
        const edgeEndPoint = [snappedBoundaryLon, interpolatedLat];
        const edgeStartPoint = [oppositeBoundaryLon, interpolatedLat];

        const lastPoint = currentRing[currentRing.length - 1];
        if (!pointsEqual(lastPoint, edgeEndPoint)) {
          currentRing.push(edgeEndPoint);
        }
        splitRings.push(closeRing(currentRing));
        currentRing = [edgeStartPoint];
        if (Math.abs(lon2 - edgeStartPoint[0]) > EPSILON || Math.abs(lat2 - edgeStartPoint[1]) > EPSILON) {
          currentRing.push([lon2, lat2]);
        }
      } else {
        currentRing.push([lon2, lat2]);
      }
    }

    splitRings.push(closeRing(currentRing));

    return splitRings.filter((candidateRing) => candidateRing.length >= 4);
  };

  const polygonToPath = (polygonCoordinates) =>
    polygonCoordinates
      .flatMap((ring) => splitRingOnDateline(ring))
      .map((ring) => {
        const path = ring
          .map(([lon, lat], index) => {
            const [x, y] = project(lon, lat);
            return `${index === 0 ? 'M' : 'L'}${x.toFixed(2)},${y.toFixed(2)}`;
          })
          .join(' ');
        return `${path} Z`;
      })
      .join(' ');

  const geometryToPath = (geometry) => {
    if (geometry.type === 'Polygon') {
      return polygonToPath(geometry.coordinates);
    }

    if (geometry.type === 'MultiPolygon') {
      return geometry.coordinates.map(polygonToPath).join(' ');
    }

    return '';
  };

  const svgNamespace = 'http://www.w3.org/2000/svg';
  const svg = document.createElementNS(svgNamespace, 'svg');
  svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
  svg.classList.add('travel-map-svg');

  const tileContainer = document.createElementNS(svgNamespace, 'g');
  const zoomLayer = document.createElementNS(svgNamespace, 'g');
  const tileDefinitions = [
    { key: 'left', offsetX: -width },
    { key: 'center', offsetX: 0 },
    { key: 'right', offsetX: width }
  ];
  const tileLayers = tileDefinitions.map(({ key, offsetX }) => {
    const tileLayer = document.createElementNS(svgNamespace, 'g');
    tileLayer.setAttribute('data-tile', key);
    tileLayer.setAttribute('transform', `translate(${offsetX}, 0)`);

    const admin0Layer = document.createElementNS(svgNamespace, 'g');
    const admin1Layer = document.createElementNS(svgNamespace, 'g');

    tileLayer.append(admin0Layer);

    return {
      tileLayer,
      admin0Layer,
      admin1Layer,
      admin1LayerMounted: false
    };
  });

  const createPath = (d, className) => {
    const path = document.createElementNS(svgNamespace, 'path');
    path.setAttribute('d', d);
    path.setAttribute('class', className);
    path.setAttribute('focusable', 'false');
    return path;
  };

  const getStatusLabel = (status) =>
    statusDisplayName[status] ?? statusMeta?.[status]?.label ?? statusDisplayName.unknown;

  const setInfoText = (regionName, status) => {
    infoRoot.textContent = `${regionName}：${getStatusLabel(status)}`;
  };

  const resetInfoText = () => {
    infoRoot.textContent = '地域にホバーすると詳細を表示します。';
  };

  const countryStatusCandidates = new Map();
  for (const feature of admin1Features) {
    const countryCode = feature?.properties?.ISO_A2;
    const admin1Id = feature?.properties?.[idKey];
    if (typeof countryCode !== 'string' || typeof admin1Id !== 'string') continue;

    const status = admin1StatusById[admin1Id] ?? 'unknown';
    if (!countryStatusCandidates.has(countryCode)) {
      countryStatusCandidates.set(countryCode, []);
    }
    countryStatusCandidates.get(countryCode).push(status);
  }

  const countryStatusByIso2 = new Map(
    [...countryStatusCandidates.entries()].map(([countryCode, statuses]) => [countryCode, aggregateStatus(statuses)])
  );

  const populateAdmin0Layer = (admin0Layer) => {
    for (const feature of admin0Features) {
      const d = geometryToPath(feature.geometry);
      if (!d) continue;

      const countryCode = feature?.properties?.ISO_A2;
      const countryStatus =
        typeof countryCode === 'string' ? countryStatusByIso2.get(countryCode) ?? 'unknown' : 'unknown';
      const path = createPath(d, 'admin0');
      const fill = statusMeta?.[countryStatus]?.color ?? statusMeta?.unknown?.color ?? '#9E9E9E';
      const countryName = feature?.properties?.NAM_0 ?? 'Unknown country';
      path.setAttribute('aria-label', `${countryName} - ${getStatusLabel(countryStatus)}`);
      path.addEventListener('mouseenter', () => setInfoText(countryName, countryStatus));
      path.addEventListener('mouseleave', resetInfoText);
      path.style.fill = fill;
      admin0Layer.append(path);
    }
  };

  const populateAdmin1Layer = (admin1Layer) => {
    for (const feature of admin1Features) {
      const d = geometryToPath(feature.geometry);
      if (!d) continue;

      const admin1Id = feature?.properties?.[idKey];
      const status = typeof admin1Id === 'string' ? admin1StatusById[admin1Id] ?? 'unknown' : 'unknown';
      const path = createPath(d, 'admin1');
      const fill = statusMeta?.[status]?.color ?? statusMeta?.unknown?.color ?? '#9E9E9E';
      const countryName = feature?.properties?.NAM_0 ?? 'Unknown country';
      const regionName = feature?.properties?.NAM_1 ?? 'Unknown region';
      const areaLabel = `${countryName} / ${regionName}`;
      path.setAttribute('aria-label', `${areaLabel} - ${getStatusLabel(status)}`);
      path.addEventListener('mouseenter', () => setInfoText(areaLabel, status));
      path.addEventListener('mouseleave', resetInfoText);
      path.style.fill = fill;
      admin1Layer.append(path);
    }
  };

  const renderAdmin1Layer = () => {
    for (const tile of tileLayers) {
      if (tile.admin1LayerMounted) continue;
      populateAdmin1Layer(tile.admin1Layer);
      if (!tile.admin1Layer.isConnected) {
        // Keep admin1 above admin0 so subdivisions remain visible when zoomed in.
        tile.tileLayer.append(tile.admin1Layer);
      }
      tile.admin1LayerMounted = true;
    }
  };

  const unmountAdmin1Layer = () => {
    for (const tile of tileLayers) {
      if (!tile.admin1LayerMounted) continue;
      tile.admin1Layer.replaceChildren();
      tile.admin1Layer.remove();
      tile.admin1LayerMounted = false;
    }
  };

  for (const tile of tileLayers) {
    populateAdmin0Layer(tile.admin0Layer);
    zoomLayer.append(tile.tileLayer);
  }

  tileContainer.append(zoomLayer);
  svg.append(tileContainer);
  mapRoot.append(svg);

  let scale = 1;
  let translateX = 0;
  let translateY = 0;
  let isDragging = false;
  let activePointerId = null;
  let dragStartX = 0;
  let dragStartY = 0;

  const normalizeTranslateX = () => {
    const worldWidth = width * scale;
    if (!Number.isFinite(worldWidth) || worldWidth <= 0) return;

    const normalizedOffset = ((-translateX % worldWidth) + worldWidth) % worldWidth;
    translateX = -normalizedOffset;
  };

  const updateScale = () => {
    const clamped = Math.max(MIN_SCALE, Math.min(MAX_SCALE, scale));
    scale = clamped;
    normalizeTranslateX();
    tileContainer.setAttribute('transform', `matrix(${clamped} 0 0 ${clamped} ${translateX} ${translateY})`);

    const showAdmin1 = clamped >= ADMIN1_VISIBLE_ZOOM;
    if (showAdmin1) {
      renderAdmin1Layer();
    } else {
      unmountAdmin1Layer();
    }

    for (const tile of tileLayers) {
      tile.admin1Layer.style.pointerEvents = showAdmin1 ? 'auto' : 'none';
      tile.admin0Layer.style.pointerEvents = showAdmin1 ? 'none' : 'auto';
      tile.admin0Layer.classList.toggle('admin0--light-overlay', showAdmin1);
      tile.admin0Layer.classList.toggle('admin0--strong', !showAdmin1);
    }
    resetInfoText();
  };

  mapRoot.addEventListener(
    'wheel',
    (event) => {
      event.preventDefault();
      const wheelDelta = Math.max(-120, Math.min(120, event.deltaY));
      const zoomFactor = Math.exp(-wheelDelta * ZOOM_SPEED);
      const nextScale = scale * zoomFactor;
      const clampedNextScale = Math.max(MIN_SCALE, Math.min(MAX_SCALE, nextScale));
      if (clampedNextScale === scale) {
        return;
      }

      const svgRect = svg.getBoundingClientRect();
      const pointerX = ((event.clientX - svgRect.left) / svgRect.width) * width;
      const pointerY = ((event.clientY - svgRect.top) / svgRect.height) * height;
      const scaleRatio = clampedNextScale / scale;

      translateX = pointerX - (pointerX - translateX) * scaleRatio;
      translateY = pointerY - (pointerY - translateY) * scaleRatio;
      scale = clampedNextScale;
      updateScale();
    },
    { passive: false }
  );

  mapRoot.addEventListener('pointerdown', (event) => {
    if (!event.isPrimary) return;
    isDragging = true;
    activePointerId = event.pointerId;
    dragStartX = event.clientX;
    dragStartY = event.clientY;
    mapRoot.setPointerCapture(event.pointerId);
    mapRoot.classList.add('travel-map--dragging');
  });

  mapRoot.addEventListener('pointermove', (event) => {
    if (!isDragging || event.pointerId !== activePointerId) return;
    const svgRect = svg.getBoundingClientRect();
    if (svgRect.width === 0 || svgRect.height === 0) return;

    const deltaX = ((event.clientX - dragStartX) / svgRect.width) * width;
    const deltaY = ((event.clientY - dragStartY) / svgRect.height) * height;
    dragStartX = event.clientX;
    dragStartY = event.clientY;
    translateX += deltaX;
    translateY += deltaY;
    updateScale();
  });

  const stopDragging = (event) => {
    if (!isDragging || event.pointerId !== activePointerId) return;
    isDragging = false;
    if (mapRoot.hasPointerCapture(event.pointerId)) {
      mapRoot.releasePointerCapture(event.pointerId);
    }
    activePointerId = null;
    mapRoot.classList.remove('travel-map--dragging');
  };

  mapRoot.addEventListener('pointerup', stopDragging);
  mapRoot.addEventListener('pointercancel', stopDragging);
  mapRoot.addEventListener('pointerleave', stopDragging);

  updateScale();
</script>

<style>
  .travel-map-card {
    gap: 1rem;
  }

  .travel-map {
    width: 100%;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--text) 16%, transparent);
    background: #05131f;
    aspect-ratio: 16 / 9;
    cursor: grab;
    touch-action: none;
    -webkit-tap-highlight-color: transparent;
  }

  .travel-map.travel-map--dragging {
    cursor: grabbing;
  }

  .travel-map-info {
    margin: 0;
    padding: 0.5rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--text) 16%, transparent);
    border-radius: 0.5rem;
    font-size: 0.875rem;
    min-height: 2.25rem;
    display: flex;
    align-items: center;
    background: color-mix(in srgb, var(--surface, #ffffff) 84%, transparent);
  }

  .travel-map-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    font-size: 0.875rem;
  }

  .travel-map-legend__item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .travel-map-legend__swatch {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 0.2rem;
    border: 1px solid color-mix(in srgb, #0f172a 25%, transparent);
  }

  :global(.travel-map-svg) {
