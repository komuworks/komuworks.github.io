---
import BaseLayout from '../../layouts/BaseLayout.astro';
const mapLoadError = false;
---

<BaseLayout title="Travel Map">
  <section class="surface-card stack travel-map-card" data-reveal>
    <h2>Travel Map</h2>

    {mapLoadError ? (
      <p role="alert">地図データを読み込めませんでした</p>
    ) : (
      <>
        <p>マウスホイールで拡大縮小、ドラッグで地図を移動できます（しきい値: 2.5）。</p>
        <p id="travel-map-loading" class="travel-map-loading" aria-live="polite">地図データを読み込み中...</p>
        <p id="travel-map-error" class="travel-map-error" role="alert" hidden>地図データを読み込めませんでした</p>
        <div id="travel-map-legend" class="travel-map-legend" aria-label="Map status legend"></div>
        <p id="travel-map-info" class="travel-map-info" aria-live="polite">地域にホバーすると詳細を表示します。</p>
        <div id="travel-map" class="travel-map" aria-label="Visited areas map"></div>
      </>
    )}
  </section>
</BaseLayout>

<script>
  const ADMIN1_VISIBLE_ZOOM = 2.5;
  const MIN_SCALE = 1;
  const MAX_SCALE = 48;
  // 東京中心相当の経験値チューニング値（初期表示のズーム/中心座標）
  const INITIAL_SCALE = 4.2;
  const INITIAL_CENTER_X = 932;
  const INITIAL_CENTER_Y = 252;
  const ZOOM_SPEED = 0.0018;
  const DATA_FILES = {
    admin0Render: '/geojson/travel-map-admin0.render.json',
    admin1Render: '/geojson/travel-map-admin1.render.json',
    visitedStatus: '/geojson/visited-status-admin1.json'
  };

  const mapRoot = document.getElementById('travel-map');
  const legendRoot = document.getElementById('travel-map-legend');
  const infoRoot = document.getElementById('travel-map-info');
  const loadingRoot = document.getElementById('travel-map-loading');
  const errorRoot = document.getElementById('travel-map-error');

  if (!mapRoot || !legendRoot || !infoRoot || !loadingRoot || !errorRoot) {
    throw new Error('Travel map initialization failed.');
  }

  const setLoadingState = (isLoading, message = '地図データを読み込み中...') => {
    loadingRoot.hidden = !isLoading;
    loadingRoot.textContent = message;
  };

  const setErrorState = (hasError, message = '地図データを読み込めませんでした') => {
    errorRoot.hidden = !hasError;
    errorRoot.textContent = message;
  };

  const fetchJson = async (path, { required = true } = {}) => {
    const response = await fetch(path);
    if (response.ok) {
      return response.json();
    }

    if (!required) return null;
    throw new Error(`Failed to load ${path}`);
  };

  // --- 状態管理: 変更されるデータ（初期値は安全な空値） ---
  let admin0Features = [];
  let admin1Features = [];
  let visitedStatusPayload = {};
  let statusMeta = {};
  let admin1StatusById = {};
  let idKey = 'ADM1CD_c';
  let countryStatusByIso2 = new Map();
  let baseDataLoaded = false;

  // --- 状態管理: admin1 詳細レイヤーの遅延ロード段階 ---
  let admin1Loaded = false;
  let admin1LoadRequested = false;
  let admin1LoadFailed = false;

  const statusDisplayName = {
    lived: '居住',
    stayed: '宿泊',
    visited: '訪問',
    passed: '通過',
    want_to_go: '行きたい',
    unknown: '未設定'
  };
  const statusPriority = ['lived', 'stayed', 'visited', 'passed', 'want_to_go', 'unknown'];
  const statusRank = new Map(statusPriority.map((status, index) => [status, index]));
  const statusPrioritySet = new Set(statusPriority);

  // ステータス正規化の単一ソース（呼び出し側では必ずこの関数を使用）
  const normalizeStatus = (status) => {
    if (typeof status !== 'string') return 'unknown';
    const normalizedStatus = status.trim().toLowerCase().replace(/\s+/g, '_');
    return statusPrioritySet.has(normalizedStatus) ? normalizedStatus : 'unknown';
  };

  const isObjectRecord = (value) => Boolean(value) && typeof value === 'object' && !Array.isArray(value);
  const buildAdmin1StatusById = (statuses) => {
    const rawStatuses = isObjectRecord(statuses) ? statuses : {};
    return Object.fromEntries(
      Object.entries(rawStatuses).map(([admin1Id, value]) => {
        const rawStatus =
          typeof value === 'string' ? value : isObjectRecord(value) ? value.status : undefined;
        return [admin1Id, normalizeStatus(rawStatus)];
      })
    );
  };

  const aggregateStatus = (statuses) => {
    let bestStatus = 'unknown';
    let bestRank = statusRank.get(bestStatus);

    for (const status of statuses) {
      const normalizedStatus = normalizeStatus(status);
      const rank = statusRank.get(normalizedStatus);
      if (rank === undefined) continue;
      if (bestRank === undefined || rank < bestRank) {
        bestStatus = normalizedStatus;
        bestRank = rank;
      }
    }

    return bestStatus;
  };

  const getAdmin1Status = (admin1Id) => {
    const rawStatus = admin1StatusById?.[admin1Id];
    if (typeof rawStatus === 'string') {
      return normalizeStatus(rawStatus);
    }

    if (isObjectRecord(rawStatus)) {
      const rawStatus =
        typeof rawStatus.status === 'string' ? rawStatus.status : undefined;
      return normalizeStatus(rawStatus);
    }

    return 'unknown';
  };

  const renderLegend = () => {
    if (!baseDataLoaded || !isObjectRecord(statusMeta)) return;
    legendRoot.replaceChildren();
    for (const status of statusPriority) {
      const meta = statusMeta?.[status];
      if (!meta) continue;

      const item = document.createElement('div');
      item.className = 'travel-map-legend__item';
      const swatch = document.createElement('span');
      swatch.className = 'travel-map-legend__swatch';
      swatch.style.backgroundColor = meta.color;
      const label = document.createElement('span');
      label.textContent = statusDisplayName[status] ?? meta.label ?? statusDisplayName.unknown;
      item.append(swatch, label);
      legendRoot.append(item);
    }
  };

  const updateCountryStatusMap = () => {
    if (!baseDataLoaded || !Array.isArray(admin1Features) || admin1Features.length === 0) {
      countryStatusByIso2 = new Map();
      return;
    }
    const countryStatusCandidates = new Map();
    for (const feature of admin1Features) {
      const countryCode = feature?.p?.ISO_A2;
      const admin1Id = feature?.p?.[idKey];
      if (typeof countryCode !== 'string' || typeof admin1Id !== 'string') continue;

      const status = getAdmin1Status(admin1Id);
      if (!countryStatusCandidates.has(countryCode)) {
        countryStatusCandidates.set(countryCode, []);
      }
      countryStatusCandidates.get(countryCode).push(status);
    }

    countryStatusByIso2 = new Map(
      [...countryStatusCandidates.entries()].map(([countryCode, statuses]) => [countryCode, aggregateStatus(statuses)])
    );
  };

  const width = 1200;
  const height = 640;
  const RENDER_PADDING_X = 20;
  const REPEAT_WIDTH = width - RENDER_PADDING_X * 2;

  const svgNamespace = 'http://www.w3.org/2000/svg';
  const svg = document.createElementNS(svgNamespace, 'svg');
  svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
  svg.classList.add('travel-map-svg');

  const tileContainer = document.createElementNS(svgNamespace, 'g');
  const zoomLayer = document.createElementNS(svgNamespace, 'g');
  const tileDefinitions = [
    { key: 'left', offsetX: -REPEAT_WIDTH },
    { key: 'center', offsetX: 0 },
    { key: 'right', offsetX: REPEAT_WIDTH }
  ];
  const tileLayers = tileDefinitions.map(({ key, offsetX }) => {
    const tileLayer = document.createElementNS(svgNamespace, 'g');
    tileLayer.setAttribute('data-tile', key);
    tileLayer.setAttribute('transform', `translate(${offsetX}, 0)`);

    const admin0Layer = document.createElementNS(svgNamespace, 'g');
    const admin1Layer = document.createElementNS(svgNamespace, 'g');

    tileLayer.append(admin0Layer);

    return {
      tileLayer,
      admin0Layer,
      admin1Layer,
      admin1LayerMounted: false
    };
  });

  const createPath = (d, className) => {
    const path = document.createElementNS(svgNamespace, 'path');
    path.setAttribute('d', d);
    path.setAttribute('class', className);
    path.setAttribute('focusable', 'false');
    return path;
  };

  const getStatusLabel = (status) =>
    statusDisplayName[status] ?? statusMeta?.[status]?.label ?? statusDisplayName.unknown;

  const setInfoText = (regionName, status) => {
    infoRoot.textContent = `${regionName}：${getStatusLabel(status)}`;
  };

  const resetInfoText = () => {
    infoRoot.textContent = '地域にホバーすると詳細を表示します。';
  };

  const populateAdmin0Layer = (admin0Layer) => {
    for (const feature of admin0Features) {
      const d = feature?.d;
      if (!d) continue;

      const countryCode = feature?.p?.ISO_A2;
      const countryStatus =
        typeof countryCode === 'string' ? countryStatusByIso2.get(countryCode) ?? 'unknown' : 'unknown';
      const path = createPath(d, 'admin0');
      const fill = statusMeta?.[countryStatus]?.color ?? statusMeta?.unknown?.color ?? '#9E9E9E';
      const countryName = feature?.p?.NAM_0 ?? 'Unknown country';
      path.setAttribute('aria-label', `${countryName} - ${getStatusLabel(countryStatus)}`);
      path.dataset.hoverLabel = countryName;
      path.dataset.hoverStatus = countryStatus;
      path.style.fill = fill;
      admin0Layer.append(path);
    }
  };

  const populateAdmin1Layer = (admin1Layer) => {
    for (const feature of admin1Features) {
      const d = feature?.d;
      if (!d) continue;

      const admin1Id = feature?.p?.[idKey];
      const status = typeof admin1Id === 'string' ? getAdmin1Status(admin1Id) : 'unknown';
      const path = createPath(d, 'admin1');
      const fill = statusMeta?.[status]?.color ?? statusMeta?.unknown?.color ?? '#9E9E9E';
      const countryName = feature?.p?.NAM_0 ?? 'Unknown country';
      const regionName = feature?.p?.NAM_1 ?? 'Unknown region';
      const areaLabel = `${countryName} / ${regionName}`;
      path.setAttribute('aria-label', `${areaLabel} - ${getStatusLabel(status)}`);
      path.dataset.hoverLabel = areaLabel;
      path.dataset.hoverStatus = status;
      path.style.fill = fill;
      admin1Layer.append(path);
    }
  };

  const renderAdmin1Layer = () => {
    for (const tile of tileLayers) {
      if (tile.admin1LayerMounted) continue;
      populateAdmin1Layer(tile.admin1Layer);
      if (!tile.admin1Layer.isConnected) {
        tile.tileLayer.append(tile.admin1Layer);
      }
      tile.admin1LayerMounted = true;
    }
  };

  const unmountAdmin1Layer = () => {
    for (const tile of tileLayers) {
      if (!tile.admin1LayerMounted) continue;
      tile.admin1Layer.replaceChildren();
      tile.admin1Layer.remove();
      tile.admin1LayerMounted = false;
    }
  };

  const rerenderAdmin0Layers = () => {
    if (!baseDataLoaded || !Array.isArray(admin0Features) || !isObjectRecord(statusMeta)) return;
    for (const tile of tileLayers) {
      tile.admin0Layer.replaceChildren();
      populateAdmin0Layer(tile.admin0Layer);
    }
  };

  for (const tile of tileLayers) {
    zoomLayer.append(tile.tileLayer);
  }

  tileContainer.append(zoomLayer);
  svg.append(tileContainer);
  mapRoot.append(svg);

  const findInteractivePath = (node) => {
    if (!(node instanceof Element)) return null;
    const path = node.closest('path.admin0, path.admin1');
    if (!path || !zoomLayer.contains(path)) return null;
    return path;
  };

  zoomLayer.addEventListener('pointerover', (event) => {
    const path = findInteractivePath(event.target);
    if (!path) return;

    const relatedPath = findInteractivePath(event.relatedTarget);
    if (relatedPath === path) return;

    const label = path.dataset.hoverLabel;
    const status = path.dataset.hoverStatus ?? 'unknown';
    if (label) {
      setInfoText(label, status);
    }
  });

  zoomLayer.addEventListener('pointerout', (event) => {
    const path = findInteractivePath(event.target);
    if (!path) return;

    const relatedPath = findInteractivePath(event.relatedTarget);
    if (relatedPath) return;
    resetInfoText();
  });

  let scale = 1;
  let translateX = 0;
  let translateY = 0;
  let isDragging = false;
  let activePointerId = null;
  let dragStartX = 0;
  let dragStartY = 0;

  const normalizeTranslateX = () => {
    const worldWidth = REPEAT_WIDTH * scale;
    if (!Number.isFinite(worldWidth) || worldWidth <= 0) return;

    const normalizedOffset = ((-translateX % worldWidth) + worldWidth) % worldWidth;
    translateX = -normalizedOffset;
  };

  const ensureAdmin1Loaded = async () => {
    if (!baseDataLoaded || admin1Loaded || admin1LoadRequested) return;

    admin1LoadRequested = true;
    admin1LoadFailed = false;
    setLoadingState(true, '詳細地図データを読み込み中...');
    try {
      const admin1MapData = await fetchJson(DATA_FILES.admin1Render);
      admin1Features = Array.isArray(admin1MapData?.features) ? admin1MapData.features : [];
      admin1Loaded = true;
      updateCountryStatusMap();
      rerenderAdmin0Layers();
      if (scale >= ADMIN1_VISIBLE_ZOOM) {
        renderAdmin1Layer();
      }
      setLoadingState(false);
    } catch {
      admin1LoadFailed = true;
      setLoadingState(false);
      setErrorState(true);
    }
  };

  const updateScale = () => {
    const clamped = Math.max(MIN_SCALE, Math.min(MAX_SCALE, scale));
    scale = clamped;
    normalizeTranslateX();
    tileContainer.setAttribute('transform', `matrix(${clamped} 0 0 ${clamped} ${translateX} ${translateY})`);

    const showAdmin1 = clamped >= ADMIN1_VISIBLE_ZOOM;
    if (showAdmin1) {
      if (admin1Loaded) {
        renderAdmin1Layer();
      } else if (!admin1LoadFailed) {
        void ensureAdmin1Loaded();
      }
    } else {
      unmountAdmin1Layer();
    }

    for (const tile of tileLayers) {
      tile.admin1Layer.style.pointerEvents = showAdmin1 ? 'auto' : 'none';
      tile.admin0Layer.style.pointerEvents = showAdmin1 ? 'none' : 'auto';
      tile.admin0Layer.classList.toggle('admin0--light-overlay', showAdmin1);
      tile.admin0Layer.classList.toggle('admin0--strong', !showAdmin1);
    }
    resetInfoText();
  };

  mapRoot.addEventListener(
    'wheel',
    (event) => {
      event.preventDefault();
      const wheelDelta = Math.max(-120, Math.min(120, event.deltaY));
      const zoomFactor = Math.exp(-wheelDelta * ZOOM_SPEED);
      const nextScale = scale * zoomFactor;
      const clampedNextScale = Math.max(MIN_SCALE, Math.min(MAX_SCALE, nextScale));
      if (clampedNextScale === scale) {
        return;
      }

      const svgRect = svg.getBoundingClientRect();
      const pointerX = ((event.clientX - svgRect.left) / svgRect.width) * width;
      const pointerY = ((event.clientY - svgRect.top) / svgRect.height) * height;
      const scaleRatio = clampedNextScale / scale;

      translateX = pointerX - (pointerX - translateX) * scaleRatio;
      translateY = pointerY - (pointerY - translateY) * scaleRatio;
      scale = clampedNextScale;
      updateScale();
    },
    { passive: false }
  );

  mapRoot.addEventListener('pointerdown', (event) => {
    if (!event.isPrimary) return;
    isDragging = true;
    activePointerId = event.pointerId;
    dragStartX = event.clientX;
    dragStartY = event.clientY;
    mapRoot.setPointerCapture(event.pointerId);
    mapRoot.classList.add('travel-map--dragging');
  });

  mapRoot.addEventListener('pointermove', (event) => {
    if (!isDragging || event.pointerId !== activePointerId) return;
    const svgRect = svg.getBoundingClientRect();
    if (svgRect.width === 0 || svgRect.height === 0) return;

    const deltaX = ((event.clientX - dragStartX) / svgRect.width) * width;
    const deltaY = ((event.clientY - dragStartY) / svgRect.height) * height;
    dragStartX = event.clientX;
    dragStartY = event.clientY;
    translateX += deltaX;
    translateY += deltaY;
    updateScale();
  });

  const stopDragging = (event) => {
    if (!isDragging || event.pointerId !== activePointerId) return;
    isDragging = false;
    if (mapRoot.hasPointerCapture(event.pointerId)) {
      mapRoot.releasePointerCapture(event.pointerId);
    }
    activePointerId = null;
    mapRoot.classList.remove('travel-map--dragging');
  };

  mapRoot.addEventListener('pointerup', stopDragging);
  mapRoot.addEventListener('pointercancel', stopDragging);
  mapRoot.addEventListener('pointerleave', stopDragging);

  const loadInitialMapData = async () => {
    setLoadingState(true);
    setErrorState(false);
    baseDataLoaded = false;
    try {
      // admin0 初期描画で参照される状態を先に確定させる
      const [admin0RenderData, visitedStatus] = await Promise.all([
        fetchJson(DATA_FILES.admin0Render),
        fetchJson(DATA_FILES.visitedStatus)
      ]);

      const renderMeta = admin0RenderData?.meta ?? {};
      if (typeof renderMeta.width === 'number' && typeof renderMeta.height === 'number') {
        svg.setAttribute('viewBox', `0 0 ${renderMeta.width} ${renderMeta.height}`);
      }

      admin0Features = Array.isArray(admin0RenderData?.features) ? admin0RenderData.features : [];
      visitedStatusPayload = visitedStatus ?? {};
      statusMeta = visitedStatusPayload?.statusMeta ?? {};
      admin1StatusById = buildAdmin1StatusById(visitedStatusPayload?.statuses);
      idKey = typeof visitedStatusPayload?.idKey === 'string' ? visitedStatusPayload.idKey : 'ADM1CD_c';
      countryStatusByIso2 = new Map();
      admin1Features = [];
      admin1Loaded = false;
      admin1LoadRequested = false;
      admin1LoadFailed = false;
      baseDataLoaded = true;
      updateCountryStatusMap();

      // 初回描画（legend/admin0/scale）は上の初期化完了後に実行する
      renderLegend();
      rerenderAdmin0Layers();
      scale = INITIAL_SCALE;
      translateX = REPEAT_WIDTH / 2 - INITIAL_CENTER_X * scale;
      translateY = height / 2 - INITIAL_CENTER_Y * scale;
      updateScale();
      setLoadingState(false);
    } catch {
      baseDataLoaded = false;
      setLoadingState(false);
      setErrorState(true);
    }
  };

  void loadInitialMapData();
</script>

<style>
  .travel-map-card {
    gap: 1rem;
  }

  .travel-map {
    width: 100%;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--text) 16%, transparent);
    background: #05131f;
    aspect-ratio: 16 / 9;
    cursor: grab;
    touch-action: none;
    -webkit-tap-highlight-color: transparent;
  }

  .travel-map.travel-map--dragging {
    cursor: grabbing;
  }

  .travel-map-info {
    margin: 0;
    padding: 0.5rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--text) 16%, transparent);
    border-radius: 0.5rem;
    font-size: 0.875rem;
    min-height: 2.25rem;
    display: flex;
    align-items: center;
    background: color-mix(in srgb, var(--surface, #ffffff) 84%, transparent);
  }

  .travel-map-loading,
  .travel-map-error {
    margin: 0;
    font-size: 0.9rem;
  }

  .travel-map-error {
    color: #dc2626;
    font-weight: 600;
  }

  .travel-map-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    font-size: 0.875rem;
  }

  .travel-map-legend__item {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .travel-map-legend__swatch {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 0.2rem;
    border: 1px solid color-mix(in srgb, #0f172a 25%, transparent);
  }

  :global(.travel-map-svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  :global(.travel-map-svg path) {
    -webkit-tap-highlight-color: transparent;
  }

  :global(.admin1) {
    stroke: #f8fafc;
    stroke-width: 0.65;
    vector-effect: non-scaling-stroke;
    transition:
      filter 140ms ease,
      opacity 140ms ease;
  }

  :global(.admin0:focus),
  :global(.admin1:focus),
  :global(.admin0:focus-visible),
  :global(.admin1:focus-visible) {
    outline: none;
  }

  :global(.admin0) {
    stroke: #f8fafc;
    vector-effect: non-scaling-stroke;
    transition:
      filter 140ms ease,
      opacity 140ms ease;
  }

  :global(.admin0:hover),
  :global(.admin1:hover),
  :global(.admin0:focus-visible),
  :global(.admin1:focus-visible) {
    filter: brightness(1.2) saturate(1.08);
    opacity: 1;
  }

  :global(.admin0--strong .admin0) {
    stroke-width: 0.95;
    opacity: 0.92;
  }

  :global(.admin0--light-overlay .admin0) {
    stroke-width: 0.55;
    opacity: 0.45;
  }
</style>
