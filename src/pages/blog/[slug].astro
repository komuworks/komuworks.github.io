---
import ArticleCard from '../../components/blog/ArticleCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/format';
import { getBlogEntryBySlug, getBlogStaticPaths } from '../../lib/content';

export async function getStaticPaths() {
  return getBlogStaticPaths();
}

const slug = Astro.params.slug;
const entry = slug ? await getBlogEntryBySlug(slug) : undefined;

if (!entry) {
  throw new Error(`Blog entry not found for slug: ${slug}`);
}
---

<BaseLayout title={entry.data.title}>
  <section class="blog-list">
    <ArticleCard
      slug={entry.data.slug}
      title={entry.data.title}
      summary={entry.data.summary}
      date={entry.data.date}
      tags={entry.data.tags}
    />
  </section>

  <section class="surface-card stack" data-reveal>
    <h2>本文</h2>
    <p class="blog-meta">日付: {formatDate(entry.data.date)}</p>
    <p>{entry.data.body}</p>
  </section>
</BaseLayout>
