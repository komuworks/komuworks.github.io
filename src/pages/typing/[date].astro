---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calcCorrectRate, validateMetrics } from '../../lib/typing';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const typingEntries = await getCollection('typing');

  return typingEntries
    .map((entry) => validateMetrics(entry.data))
    .filter((entry): entry is NonNullable<typeof entry> => entry !== null)
    .map((metric) => ({
      params: { date: metric.date },
    }));
}

const date = Astro.params.date;
const typingEntry = date ? await getEntry('typing', date) : undefined;
const metric = typingEntry ? validateMetrics(typingEntry.data) : null;

if (!metric) {
  throw new Error(`Typing metric not found for date: ${date}`);
}
---

<BaseLayout title={`Typing ${metric.date}`}>
  <h1>タイピング詳細</h1>
  <p class="blog-meta">日付: {metric.date}</p>
  <p>総入力文字数: {metric.totalChars}</p>
  <p>正確キー数: {metric.correctKeys}</p>
  <p>エラーキー数: {metric.errorKeys}</p>
  <p>セッション時間: {metric.sessionMinutes.toFixed(2)} 分</p>
  <p>正確率: {calcCorrectRate(metric.correctKeys, metric.errorKeys).toFixed(2)}%</p>
</BaseLayout>
