---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calcCorrectRate } from '../../lib/typing';
import { getTypingMetricByDate, getTypingStaticPaths } from '../../lib/content';

export async function getStaticPaths() {
  return getTypingStaticPaths();
}

const date = Astro.params.date;
const metric = date ? await getTypingMetricByDate(date) : null;

if (!metric) {
  throw new Error(`Typing metric not found for date: ${date}`);
}
---

<BaseLayout title={`Typing ${metric.date}`}>
  <section class="surface-card stack" data-reveal>
    <h2>タイピング詳細</h2>
    <p class="blog-meta">日付: {metric.date}</p>
    <p>入力文字数: {metric.totalChars}</p>
    <p>正タイプ数: {metric.correctKeys}</p>
    <p>誤タイプ数: {metric.errorKeys}</p>
    <p>時間: {metric.sessionMinutes.toFixed(2)} 分</p>
    <p>正タイプ率: {calcCorrectRate(metric.correctKeys, metric.errorKeys).toFixed(2)}%</p>
  </section>
</BaseLayout>
