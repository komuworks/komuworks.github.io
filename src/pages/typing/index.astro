---
import TypingChart from '../../components/typing/TypingChart.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calcCorrectRate } from '../../lib/typing';
import { toTypingDetail } from '../../lib/url';
import { getTypingMetricsByDateDesc } from '../../lib/content';

const metrics = await getTypingMetricsByDateDesc();
---

<BaseLayout title="Typing">
  <TypingChart metrics={metrics} />

  <ul class="typing-list" data-reveal>
    {metrics.map((entry) => (
      <li class="metric-card">
        <a href={toTypingDetail(entry.date)}>{entry.date}</a>
        <p class="blog-meta">
          正タイプ率: {calcCorrectRate(entry.correctKeys, entry.errorKeys).toFixed(2)}%
        </p>
      </li>
    ))}
  </ul>
</BaseLayout>
