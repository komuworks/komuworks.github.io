---
import TypingChart from '../../components/typing/TypingChart.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calcCorrectRate, validateMetrics } from '../../lib/typing';
import { toTypingDetail } from '../../lib/url';
import { getCollection } from 'astro:content';

const typingEntries = await getCollection('typing');
const metrics = typingEntries
  .map((entry) => validateMetrics(entry.data))
  .filter((entry): entry is NonNullable<typeof entry> => entry !== null)
  .sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout title="Typing">
  <TypingChart metrics={metrics} />

  <ul class="typing-list" data-reveal>
    {metrics.map((entry) => (
      <li class="metric-card">
        <a href={toTypingDetail(entry.date)}>{entry.date}</a>
        <p class="blog-meta">
          正確率: {calcCorrectRate(entry.correctKeys, entry.errorKeys).toFixed(2)}%
        </p>
      </li>
    ))}
  </ul>
</BaseLayout>
