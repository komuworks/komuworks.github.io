---
import BaseLayout from '../layouts/BaseLayout.astro';
import { toHome } from '../lib/url';
---

<BaseLayout title="404 Not Found">
  <section class="surface-card stack" data-reveal>
    <h2>404</h2>
    <p>ページが見つかりません。URLをご確認ください。</p>
    <p><a href={toHome()}>ホームへ戻る</a></p>
  </section>
</BaseLayout>
